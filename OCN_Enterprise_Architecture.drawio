        <mxCell id="t1_ocn" value="&lt;b&gt;&amp;#128230; OCN — Order Capture Network&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;[Software System — Owned]&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Captures order emails, extracts structured data&lt;br/&gt;via AI/OCR, creates draft orders for review&lt;/font&gt;" style="rounded=1;arcSize=5;whiteSpace=wrap;html=1;fillColor=#1565C0;strokeColor=#0D47A1;fontColor=#FFFFFF;fontSize=11;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="620" y="240" width="300" height="125" as="geometry"/></mxCell>
