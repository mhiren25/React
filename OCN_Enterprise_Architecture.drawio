        <mxCell id="t1_leg" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br/&gt;&amp;#9632; &lt;b&gt;&lt;font color=&#x27;#546E7A&#x27;&gt;Grey&lt;/font&gt;&lt;/b&gt; = External system&lt;br/&gt;&amp;#9632; &lt;b&gt;&lt;font color=&#x27;#1565C0&#x27;&gt;Blue&lt;/font&gt;&lt;/b&gt; = Owned by this programme&lt;br/&gt;&lt;i&gt;Hides Red Zone CID detail — see Tab 2&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="60" y="460" width="340" height="100" as="geometry"/></mxCell>
